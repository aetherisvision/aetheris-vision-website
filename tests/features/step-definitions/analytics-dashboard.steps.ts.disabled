  expect(screen.getByText('Active Users')).toBeInTheDocument();
  
  // Check for trending arrows
  const trendingIcons = container.querySelectorAll('svg[data-slot="icon"]');
  expect(trendingIcons.length).toBeGreaterThan(0);
