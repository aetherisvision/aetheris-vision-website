import { Given, When, Then } from '@cucumber/cucumber';
import { expect } from 'vitest';
import { render, screen, fireEvent, waitFor, within } from '@testing-library/react';
import '@testing-library/jest-dom';
import AnalyticsDashboardPage from '../../../src/app/portfolio/analytics-dashboard/page';

// Shared test context
let dashboardComponent: any;
let container: HTMLElement;

// Mock viewport dimensions for responsive testing
const setViewportSize = (width: number) => {
  Object.defineProperty(window, 'innerWidth', {
    writable: true,
    configurable: true,
    value: width,
  });
  window.dispatchEvent(new Event('resize'));
};

Given('I am viewing the analytics dashboard demo page', async function () {
  const rendered = render(<AnalyticsDashboardPage />);
  dashboardComponent = rendered;
  container = rendered.container;
});

Given('the page has finished loading all components', async function () {
  // Wait for all components to be rendered
  await waitFor(() => {
    expect(screen.getByText('DataViz Pro Analytics')).toBeInTheDocument();
    expect(screen.getByText('Real-time performance monitoring dashboard')).toBeInTheDocument();
  });
});

Given('there are active system alerts displayed', async function () {
  await waitFor(() => {
    const alertsSection = screen.getByText('System Alerts');
    expect(alertsSection).toBeInTheDocument();
  });
});

Given('the default timeframe is "Last 24 Hours"', async function () {
  const timeframeSelect = screen.getByRole('combobox');
  expect(timeframeSelect).toHaveValue('24h');
});

Given('I arrived from the main portfolio page', async function () {
  // This would normally involve navigation state, but for testing we verify the demo banner
  expect(screen.getByText(/LIVE DEMO — built by/)).toBeInTheDocument();
});

When('I arrive on the dashboard', async function () {
  // Component is already rendered, just verify presence
  expect(screen.getByText('DataViz Pro Analytics')).toBeInTheDocument();
});

When('I view the user activity chart', async function () {
  const chartSection = screen.getByText('User Activity (24h)');
  expect(chartSection).toBeInTheDocument();
});

When('I view the weekly revenue chart', async function () {
  const revenueChart = screen.getByText('Weekly Revenue');
  expect(revenueChart).toBeInTheDocument();
});

When('I examine the system performance section', async function () {
  const performanceSection = screen.getByText('System Performance');
  expect(performanceSection).toBeInTheDocument();
});

When('I click the resolve button on an unresolved alert', async function () {
  // Find the first unresolved alert's resolve button
  const alertButtons = screen.getAllByRole('button');
  const resolveButtons = alertButtons.filter(button => 
    button.querySelector('svg') && 
    !button.textContent?.includes('Refresh') &&
    !button.textContent?.includes('Close Demo')
  );
  
  if (resolveButtons.length > 0) {
    fireEvent.click(resolveButtons[0]);
  }
});

When('I change the timeframe dropdown to {string}', async function (timeframe: string) {
  const timeframeSelect = screen.getByRole('combobox');
  const valueMap: Record<string, string> = {
    'Last 7 Days': '7d',
    'Last Hour': '1h',
    'Last 30 Days': '30d'
  };
  
  fireEvent.change(timeframeSelect, { target: { value: valueMap[timeframe] } });
});

When('I click the refresh button', async function () {
  const refreshButton = screen.getByRole('button', { name: /refresh/i });
  fireEvent.click(refreshButton);
});

When('I view the dashboard on a mobile device ({int}px width)', async function (width: number) {
  setViewportSize(width);
});

When('I view the dashboard on a tablet ({int}px width)', async function (width: number) {
  setViewportSize(width);
});

When('I view the dashboard on desktop ({int}px+ width)', async function (width: number) {
  setViewportSize(width);
});

When('I use keyboard navigation only', async function () {
  // Focus on first interactive element
  const timeframeSelect = screen.getByRole('combobox');
  timeframeSelect.focus();
});

When('I use a screen reader', async function () {
  // Verify ARIA attributes are present
  const charts = container.querySelectorAll('[role="img"], [aria-label]');
  expect(charts.length).toBeGreaterThan(0);
});

When('multiple users access the dashboard simultaneously', async function () {
  // Simulate concurrent access by rendering multiple instances
  render(<AnalyticsDashboardPage />);
  render(<AnalyticsDashboardPage />);
});

When('I leave the dashboard idle for extended periods', async function () {
  // Fast-forward timers to simulate idle time
  vi.advanceTimersByTime(300000); // 5 minutes
});

When('the data refresh encounters a temporary error', async function () {
  // Mock a network error scenario
  const originalFetch = global.fetch;
  global.fetch = vi.fn().mockRejectedValue(new Error('Network error'));
  
  const refreshButton = screen.getByRole('button', { name: /refresh/i });
  fireEvent.click(refreshButton);
  
  // Restore fetch
  global.fetch = originalFetch;
});

When('network connectivity is intermittent', async function () {
  // Simulate intermittent connectivity
  let callCount = 0;
  global.fetch = vi.fn().mockImplementation(() => {
    callCount++;
    if (callCount % 2 === 0) {
      return Promise.reject(new Error('Network timeout'));
    }
    return Promise.resolve(new Response('{}'));
  });
});

When('I hover over chart elements', async function () {
  const chartElements = container.querySelectorAll('svg, canvas, [data-chart]');
  if (chartElements.length > 0) {
    fireEvent.mouseEnter(chartElements[0]);
  }
});

When('I interact with the alert resolution system', async function () {
  const alertButtons = screen.getAllByRole('button');
  const resolveButton = alertButtons.find(button => 
    button.querySelector('svg') && !button.textContent?.includes('Refresh')
  );
  
  if (resolveButton) {
    fireEvent.click(resolveButton);
  }
});

When('I rapidly interact with multiple controls', async function () {
  const timeframeSelect = screen.getByRole('combobox');
  const refreshButton = screen.getByRole('button', { name: /refresh/i });
  
  // Rapid interactions
  for (let i = 0; i < 5; i++) {
    fireEvent.change(timeframeSelect, { target: { value: i % 2 === 0 ? '1h' : '7d' } });
    fireEvent.click(refreshButton);
  }
});

When('I click the {string} button', async function (buttonText: string) {
  const button = screen.getByRole('button', { name: new RegExp(buttonText, 'i') });
  fireEvent.click(button);
});

When('I click the company name link in the demo banner', async function () {
  const companyLink = screen.getByRole('link', { name: /ATAQ Web/ });
  fireEvent.click(companyLink);
});

